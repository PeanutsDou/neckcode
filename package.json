{
    "name":  "deepseekcode",
    "version":  "0.1.5",
    "description":  "Desktop GUI coding assistant with multi-model support",
    "private":  true,
    "main":  "dist/main/index.js",
    "scripts":  {
                    "dev":  "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
                    "dev:main":  "npm run build:main \u0026\u0026 node node_modules/electron/cli.js .",
                    "dev:renderer":  "node node_modules/vite/bin/vite.js --config config/vite.config.ts",
                    "build:main":  "tsc -p config/tsconfig.main.json",
                    "build:renderer":  "node node_modules/vite/bin/vite.js build --config config/vite.config.ts",
                    "build":  "npm run build:main \u0026\u0026 npm run build:renderer",
                    "start":  "node node_modules/electron/cli.js .",
                    "pack":  "npm run build \u0026\u0026 electron-builder --dir",
                    "dist":  "npm run build \u0026\u0026 electron-builder",
                    "postinstall":  "npx @electron/rebuild"
                },
    "build":  {
                  "appId":  "com.peanuts.deepseekcode",
                  "productName":  "DeepSeek Code",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/**/*",
                                "resources/**/*",
                                "package.json"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "resources/",
                                             "to":  "resources/"
                                         }
                                     ],
                  "win":  {
                              "target":  "nsis",
                              "icon":  "resources/icon.ico"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "perMachine":  false,
                               "allowToChangeInstallationDirectory":  true
                           },
                  "publish":  {
                                  "provider":  "github",
                                  "owner":  "PeanutsDou",
                                  "repo":  "deepseekcode"
                              },
                  "asarUnpack":  [
                                     "node_modules/better-sqlite3/**",
                                     "node_modules/mermaid/**"
                                 ]
              },
    "dependencies":  {
                         "@anthropic-ai/sdk":  "^0.95.1",
                         "@monaco-editor/react":  "^4.7.0",
                         "@xterm/addon-fit":  "^0.11.0",
                         "better-sqlite3":  "^12.9.0",
                         "electron-updater":  "^6.8.3",
                         "gpt-tokenizer":  "^3.4.0",
                         "mermaid":  "^11.14.0",
                         "monaco-editor":  "^0.55.1",
                         "react":  "^19.0.0",
                         "react-dom":  "^19.0.0",
                         "react-markdown":  "^9.0.0",
                         "rehype-highlight":  "^7.0.0",
                         "remark-breaks":  "^4.0.0",
                         "remark-gfm":  "^4.0.0",
                         "xterm":  "^5.3.0",
                         "zustand":  "^5.0.0"
                     },
    "devDependencies":  {
                            "@electron/rebuild":  "^4.0.4",
                            "@types/better-sqlite3":  "^7.6.13",
                            "@types/react":  "^19.0.0",
                            "@types/react-dom":  "^19.0.0",
                            "@vitejs/plugin-react":  "^4.0.0",
                            "concurrently":  "^9.0.0",
                            "electron":  "^33.0.0",
                            "electron-builder":  "^26.8.1",
                            "rcedit":  "^5.0.1",
                            "typescript":  "^5.7.0",
                            "vite":  "^6.0.0"
                        }
}
