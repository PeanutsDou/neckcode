{
  "name": "deepseekcode",
  "version": "0.1.0",
  "description": "Desktop GUI coding assistant with multi-model support",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "npm run build:main && node node_modules/electron/cli.js .",
    "dev:renderer": "node node_modules/vite/bin/vite.js --config vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "node node_modules/electron/cli.js ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "xterm": "^5.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
